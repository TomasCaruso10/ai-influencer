  },
  "7": {
    "inputs": {
      "text": "child, teen, minor, underage, kid, schoolgirl, loli, young girl, adolescent, immature, low quality, blurry, deformed, bad anatomy, extra limbs, watermark, text",
      "clip": ["5b", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "NEGATIVE"}
  },
  "8": {
    "inputs": {"width": 1024, "height": 1024, "batch_size": 1},
