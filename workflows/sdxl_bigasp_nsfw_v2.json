  },
  "5b": {
    "_comment": "IPAdapter FaceID LoRA helper (required by FaceID Plus v2)",
    "inputs": {
      "lora_name": "ip-adapter-faceid-plusv2_sdxl_lora.safetensors",
      "strength_model": 0.65,
      "strength_clip": 0.65,
      "model": ["5", 0],
      "clip": ["5", 1]
    },
    "class_type": "LoraLoader",
    "_meta": {"title": "IPAdapter FaceID LoRA"}
  },
  "5c": {
    "_comment": "IPAdapter FaceID Plus v2 — refuerza identidad usando foto canon como referencia",
    "inputs": {
      "model": ["5b", 0],
      "ipadapter": ["5d", 0],
      "image": ["5e", 0],
      "weight": 0.75,
      "weight_faceidv2": 0.85,
      "weight_type": "linear",
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
