    "class_type": "IPAdapterFaceID",
    "_meta": {"title": "IPAdapter FaceID Plus v2"}
  },
  "5d": {
    "inputs": {"preset": "FACEID PLUS V2", "lora_strength": 0.65, "provider": "CUDA", "model": ["5b", 0]},
