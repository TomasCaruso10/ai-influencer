# Copiar a `.env` y completar con valores reales. .env está gitignored.

# ============================================================
# RunPod
# ============================================================

# API key — generar en https://www.runpod.io/console/user/settings → "API Keys"
RUNPOD_API_KEY=

# ID del Network Volume creado en https://www.runpod.io/console/user/storage
# Lo encontrás en la URL del volume o en su detalle. Formato: 25 chars alfanuméricos.
RUNPOD_VOLUME_ID=

# GPU type ID exacto. Default razonable para MVP:
#   "NVIDIA GeForce RTX 4090"
# Otros válidos:
#   "NVIDIA GeForce RTX 3090"
#   "NVIDIA A40"
#   "NVIDIA H100 80GB HBM3"
RUNPOD_GPU_TYPE=NVIDIA GeForce RTX 4090

# Cloud type: COMMUNITY (más barato, hardware de partners) o SECURE (Tier IV datacenters)
RUNPOD_CLOUD_TYPE=COMMUNITY

# Imagen Docker base. Default: ai-dock/comfyui (ComfyUI ya viene levantado).
RUNPOD_IMAGE=ghcr.io/ai-dock/comfyui:latest-cuda

# Disco container (ephemeral). 50 GB alcanza si todo el state vive en el network volume.
RUNPOD_CONTAINER_DISK_GB=50

# SSH public key para acceder al pod via SSH directo.
# Generar (si no tenés): ssh-keygen -t ed25519 -C "ai-influencer-mvp"
# Luego: pegá el contenido de ~/.ssh/id_ed25519.pub aquí (en una sola línea).
RUNPOD_SSH_PUBKEY=

# (Opcional) Región preferida. Si no se especifica, RunPod elige por disponibilidad.
# Valores típicos baratos: EU-RO-1, CA-MTL-1, US-OR-1.
# RUNPOD_REGION=EU-RO-1

# ============================================================
# ComfyUI HTTP target (cuando estés generando)
# Después de `pod up`, el script imprime esta URL y la podés exportar:
# ============================================================
# COMFY_URL=https://<pod-id>-8188.proxy.runpod.net

# ============================================================
# fal.ai (post-MVP, generación SFW serverless)
# ============================================================
# FAL_KEY=

# ============================================================
# Kling 2.0 (vía fal.ai u otra API, post-MVP)
# ============================================================
# KLING_API_KEY=
